<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/" xmlns:set="http://www.sitecore.net/xmlconfig/set/" xmlns:role="http://www.sitecore.net/xmlconfig/role/" xmlns:marketingDefinitionsAssignment="http://www.sitecore.net/xmlconfig/trackingMarketingDefinitionsAssignment/">
	<sitecore>
		<links>
			<urlBuilder>
				<useDisplayName>true</useDisplayName>
				<lowercaseUrls>true</lowercaseUrls>
				<languageEmbedding>never</languageEmbedding>
			</urlBuilder>
		</links>
		<linkManager defaultProvider="sitecore">
			<patch:attribute name="defaultProvider">switchableLinkProvider</patch:attribute>
			<providers>
				<add name="sitecore" type="Sitecore.Links.LinkProvider, Sitecore.Kernel" languageEmbedding="never" shortenUrls="true" useDisplayName="true" resolve="true"/>
				<add name="switchableLinkProvider" type="Sitecore.XA.Foundation.Multisite.LinkManagers.SwitchableLinkProvider, Sitecore.XA.Foundation.Multisite"/>
				<add name="localizedProvider" type="Sitecore.XA.Foundation.Multisite.LinkManagers.LocalizableLinkProvider, Sitecore.XA.Foundation.Multisite" cacheExpiration="5" addAspxExtension="false" alwaysIncludeServerUrl="false" encodeNames="true" languageEmbedding="never" languageLocation="filePath" shortenUrls="true" useDisplayName="true"/>
			</providers>
		</linkManager>
		<settings>
			<setting name="Query.MaxItems" value="1500"></setting>
		</settings>
	</sitecore>
</configuration>