{
  "name": "sxastarter",
  "description": "Application utilizing Sitecore JavaScript Services and Next.js",
  "version": "0.1.0",
  "private": true,
  "config": {
    "appName": "sxastarter",
    "rootPlaceholders": [
      "jss-main"
    ],
    "sitecoreConfigPath": "/App_Config/Include/zzz",
    "graphQLEndpointPath": "/sitecore/api/graph/edge",
    "language": "en",
    "templates": [
      "nextjs",
      "nextjs-xmcloud",
      "nextjs-sxa",
      "nextjs-multisite"
    ]
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://jss.sitecore.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/jss.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/jss/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@googlemaps/react-wrapper": "^1.2.0",
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.0.18",
    "@mui/icons-material": "^5.15.0",
    "@next/bundle-analyzer": "^14.0.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@sitecore-cloudsdk/search": "^0.5.4",
    "@sitecore-content-sdk/analytics-core": "^2.0.0",
    "@sitecore-content-sdk/events": "^2.0.0",
    "@sitecore-content-sdk/nextjs": "^2.0.0",
    "@sitecore-content-sdk/personalize": "^2.0.0",
    "@sitecore-feaas/clientside": "^0.6.0",
    "@sitecore/components": "~2.1.0",
    "@storybook/addon-actions": "^7.6.5",
    "@storybook/react": "^9.0.18",
    "@storybook/testing-library": "^0.2.2",
    "@supabase/supabase-js": "^2.81.1",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vimeo/player": "^2.30.1",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.16",
    "bootstrap": "^5.1.3",
    "css-loader": "^6.8.1",
    "dompurify": "^3.2.4",
    "font-awesome": "^4.7.0",
    "formik": "^2.4.6",
    "geonames.js": "^3.0.3",
    "groq-sdk": "^0.29.0",
    "lucide-react": "^0.536.0",
    "next": "^16.1.1",
    "next-localization": "^0.12.0",
    "next-share": "^0.27.0",
    "nextjs-progressbar": "^0.0.16",
    "node-cron": "^3.0.3",
    "openai": "^5.23.2",
    "postcss": "^8.4.32",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-intersection-observer": "^9.5.3",
    "react-markdown": "^10.1.0",
    "react-responsive": "^10.0.0",
    "react-spinners": "^0.17.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.52.3",
    "sass-alias": "^1.0.5",
    "sass-loader": "^13.3.2",
    "sharp": "0.32.6",
    "storybook": "^9.0.18",
    "style-loader": "^3.3.3",
    "typescript-cookie": "^1.0.6",
    "usehooks-ts": "^3.1.0",
    "uuid": "^9.0.1",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@sitecore-content-sdk/cli": "^2.0.0",
    "@sitecore-jss/sitecore-jss-dev-tools": "^22.12.3",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.10.4",
    "@types/node-cron": "^3.0.11",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "chalk": "~4.1.2",
    "chokidar": "~3.5.3",
    "constant-case": "^3.0.4",
    "cross-env": "~7.0.3",
    "dotenv-flow": "^4.1.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^13.1.5",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-yaml": "^0.5.0",
    "npm-run-all": "~4.1.5",
    "prettier": "^2.8.3",
    "tailwind-scrollbar-hide": "^1.1.7",
    "tailwindcss": "^3.3.7",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "~5.4.0",
    "vitest": "^3.0.9",
    "yaml-loader": "^0.8.0"
  },
  "scripts": {
    "bootstrap": "ts-node --require dotenv-flow/config --project tsconfig.scripts.json scripts/bootstrap.ts",
    "build": "cross-env NODE_ENV=production npm-run-all --serial bootstrap next:build",
    "install-pre-push-hook": "ts-node --project tsconfig.scripts.json ./scripts/install-pre-push-hook.ts",
    "jss": "jss",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts ./scripts/**/*.ts",
    "next:build": "next build --webpack --debug",
    "next:dev": "next dev",
    "next:dev:inspect": "cross-env NODE_OPTIONS='--inspect' next dev",
    "next:start": "next start",
    "scaffold": "ts-node --project tsconfig.scripts.json scripts/scaffold-component/index.ts",
    "start:connected": "cross-env NODE_ENV=development npm-run-all --serial bootstrap  --parallel --loglevel=error next:dev start:watch-components",
    "start:production": "cross-env-shell NODE_ENV=production npm-run-all --serial bootstrap --loglevel=error next:build next:start",
    "start:watch-components": "ts-node --project tsconfig.scripts.json scripts/generate-component-builder/index.ts --watch"
  },
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all"
  ]
}
